# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/french-tutor-ai

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# API Keys (Add your actual keys in .env file, not in this example)
# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key

# Google Cloud API Keys (for Speech-to-Text and Text-to-Speech)
GOOGLE_APPLICATION_CREDENTIALS=path_to_your_google_credentials_file

# Azure Cognitive Services (alternative for speech services)
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=your_azure_region

# LanguageTool API (for grammar checking)
LANGUAGETOOL_API_URL=https://api.languagetool.org